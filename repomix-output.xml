export default function SketchLine({ containerClassName = "" }) {
  return (
    <div className={`relative z-10 mx-auto w-full flex items-center justify-center overflow-visible ${containerClassName}`.trim()}>
      <motion.svg
        className="pointer-events-none h-auto w-full max-h-[60vh] sm:max-h-[80vh] overflow-visible px-4"
        viewBox="0 0 1029 307"
        preserveAspectRatio="xMidYMid meet"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        {PATHS.map((d, index) => (
          <motion.path
            key={index}
            d={d}
            stroke="#E8E6E1"
            strokeWidth="2.5"
            strokeLinecap="round"
            strokeLinejoin="round"
            initial={{ pathLength: 0, fill: "rgba(232, 230, 225, 0)" }}
            whileInView={{ 
              pathLength: 1, 
              fill: "rgba(232, 230, 225, 1)",
            }}
            viewport={{ once: true }}
            transition={{
              pathLength: { duration: 1.2, delay: index * 0.15, ease: "easeInOut" },
              fill: { duration: 0.6, delay: (index * 0.15) + 0.8, ease: "easeIn" }
            }}
          />
        ))}
      </motion.svg>
    </div>
  );
}
